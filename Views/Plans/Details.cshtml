@model Plan

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="author" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Baloo+Thambi+2:wght@400..800&family=Rubik:ital,wght@0,300..900;1,300..900&display=swap"
    rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <!-- ^ Bootstrap 5.3.8 css file -->
    <a href="c:\users\acer\desktop\graphicsassignment\gymsystem\wwwroot\lib\bootstrap\dist\css\bootstrap.min.css.map"></a>
    <link href="c:\users\acer\desktop\graphicsassignment\gymsystem\wwwroot\lib\bootstrap\dist\css\bootstrap.min.css" rel="stylesheet"/>
    <!-- ^ Our main css file -->
    <link rel="stylesheet" href="~/css/style.css" />
    <title>Power fitness | Home</title> 
</head>

<body>
    <div class="container">
        <main role="main" class="pb-3">

            <div class="container mt-5">
                <div class="row justify-content-center">
                    <div class="col-md-6">
                        <div class="card shadow-lg border-0">
                            @* If Plan is Active put class bg-primary-color if not bg-secondary *@

                            <div class="card-header text-white text-center py-5 @(Model.IsActive ? "bg-primary-color" : "bg-secondary")">
                                <i class="bi bi-award display-4 mb-3"></i>
                                <h2 class="mb-0">@Model.Name</h2>
                            </div>
                            <div class="card-body p-4">
                                <div class="text-center mb-4 py-3 bg-light rounded">
                                    <div class="display-3 fw-bold text-primary-color">@Model.Price</div>
                                    <small class="text-muted fs-5">EGP</small>
                                </div>

                                <div class="plan-details">
                                    <div class="detail-item mb-4">
                                        <div class="d-flex align-items-center mb-2">
                                            <div class="icon-box me-3">
                                                <i class="bi bi-calendar-check text-primary-color fs-4"></i>
                                            </div>
                                            <div>
                                                <h6 class="mb-0 text-muted">Duration</h6>
                                                <p class="mb-0 fw-bold">@Model.DurationDays</p>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="detail-item mb-4">
                                        <div class="d-flex align-items-start mb-2">
                                            <div class="icon-box me-3">
                                                <i class="bi bi-file-text text-primary-color fs-4"></i>
                                            </div>
                                            <div class="flex-grow-1">
                                                <h6 class="mb-2 text-muted">Description</h6>
                                                <p class="mb-0">@Model.Description</p>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="detail-item mb-4">
                                        <div class="d-flex align-items-center mb-2">
                                            <div class="icon-box me-3">
                                                @* If Plan is Active put class bi-check-circle-fill text-success if not bi-x-circle-fill text-danger *@
                                                <i class="bi fs-4 @(Model.IsActive ? "bi-check-circle-fill text-success" : "bi-x-circle-fill text-danger")"></i>
                                            </div>
                                            <div>
                                                <h6 class="mb-0 text-muted">Status</h6>
                                                <p class="mb-0">
                                                    @* If Plan is Active *@
                                                    @if (Model.IsActive)
                                                    {
                                                        <span class="badge bg-success">
                                                            Active
                                                        </span>
                                                    }
                                                    else
                                                    {
                                                        @* If Plan is Inactive *@
                                                        @* If Plan is Inactive *@
                                                        <span class="badge bg-danger">
                                                            Inactive
                                                        </span>
                                                    }
                                                </p>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="card-footer bg-white border-0 p-4">
                                <div class="d-flex justify-content-between gap-2">
                                    <a asp-action="Index" class="btn btn-outline flex-fill">
                                        <i class="bi bi-arrow-left me-1"></i>Back
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>
</body>
</html>